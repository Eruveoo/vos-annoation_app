# Remote backend (shared GPU machine). Copy to .env and adjust.
# .env is gitignored — each developer creates their own copy.
#
# macOS: Finder cannot create ".env" (dot names are blocked). Use Terminal:
#   cd frontend && ./setup-env.sh https://your-tunnel.pinggy.link USER PASSWORD
# Or create the file in Cursor/VS Code (File → New → save as ".env").
#
# Shared backend (uvicorn + Pinggy tunnel with optional basic auth).
# In dev, Vite proxies /api → VITE_API_URL and adds auth (avoids browser CORS issues).
VITE_API_URL=https://your-tunnel.pinggy.link
VITE_API_USER=your-username
VITE_API_PASSWORD=your-tunnel-password
#
# Local backend (default if VITE_API_URL is unset):
#   uses http://127.0.0.1:12212 — no auth needed
