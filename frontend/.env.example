# Remote backend (shared GPU machine). Copy to .env and adjust.
# .env is gitignored — each developer creates their own copy.
#
# Shared backend (one person runs uvicorn + Pinggy tunnel):
#   VITE_API_URL=https://your-tunnel.pinggy.link
#
# Local backend on same machine as the browser (default if unset):
#   # leave VITE_API_URL unset — api.js uses http://127.0.0.1:12212
#
VITE_API_URL=https://your-tunnel.pinggy.link
